# Stripe Configuration
# Get your secret key from: https://dashboard.stripe.com/apikeys
# IMPORTANT: Never commit the real .env file to git!
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY

# Your website domain
# Use http://localhost:8888 for local testing with Netlify CLI
# Use https://cerafica.com for production
CERAFICA_DOMAIN=https://cerafica.com

# Optional: Stripe Webhook Secret (for receiving payment confirmations)
# Get your webhook secret from: https://dashboard.stripe.com/webhooks
# STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# AI Services
# OpenRouter API key (fallback for caption generation when Ollama is unavailable)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-REPLACE_WITH_YOUR_KEY

# Feedback Server
# Random token for authenticating feedback pipeline requests
FEEDBACK_AUTH_TOKEN=REPLACE_WITH_A_RANDOM_SECRET

# Path to logo PNG (used by frame_generator.py)
# Defaults to ~/Library/Mobile Documents/com~apple~CloudDocs/Cerafica Design/PNGs/CeraficaIcon Gradient@4x.png
# CERAFICA_LOGO_PATH=

# Directory for exported media (used by create_slideshow.py)
# Defaults to ~/Downloads/cerafica_exports
# CERAFICA_EXPORTS_DIR=
